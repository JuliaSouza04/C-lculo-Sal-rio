<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Salário</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        header {
            background-color: #2c3e50;
            color: white;
            padding: 1rem 2rem;
            text-align: center;
            font-size: 1.5rem;
            font-weight: bold;
        }

        nav {
            background-color: #34495e;
            color: white;
            padding: 0.5rem 2rem;
            display: flex;
            gap: 20px;
        }

        nav a {
            color: #ecf0f1;
            text-decoration: none;
            font-size: 0.9rem;
        }

        nav a:hover {
            text-decoration: underline;
        }

        .main-layout {
            display: flex;
            flex: 1; 
        }
    
        aside {
            width: 250px;
            background-color: #f4f4f4;
            border-right: 1px solid #ddd;
            padding: 20px;
        }

        .container {
            flex: 1;
            padding: 40px;
            background-color: #2c3e50;
        }

        .container-placeholder {
            border: 2px dashed #ffffff;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #999;
            gap: 15px;
            flex-wrap: wrap;
        }
        .box {
            background-color: #34495e;
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #5f7a94;
            color: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 10px;
        }

        .box input {
            padding: 5px;
            border-radius: 4px;
            border: none;
        }

        .box button {
            padding: 10px 20px;
            border: none;
            border-radius: 4px;
            background-color: #1abc9c;
            color: white;
            cursor: pointer;
            font-weight: bold;
        }

        .coluna {
            display: flex;
            flex-direction: column;
            gap: 50px;
            align-items: center; 
            margin-top: -10px;
        }

        .resultado-box {
            width: 100%; 
            display: flex;
            flex-direction: column;
            align-items: center; 
            gap: 5px;
        }

        .box button:hover {
            background-color: #16a085;
        }

        table {
            border-collapse: collapse;
            color: white;
            width: 300px;
            text-align: center;
        }
        
        table th {
            background-color: #34495e;
            padding: 10px;
            border: 1px solid #5f7a94;
        }

        table td {
            background-color: #2c3e50;
            padding: 15px;
            border: 1px solid #5f7a94;
            font-size: 1.1rem;
            font-weight: bold;
            color: #1abc9c;
        }
    </style>
</head>
<body>

    <header>
        Sistema de RH - Gestão de Salários
    </header>

    <nav>
        <a href="#">Início</a>
        <a href="#">Relatórios</a>
        <a href="#">Configurações</a>
        <a href="#">Sair</a>
    </nav>

    <div class="main-layout">
        <aside>
            <h3>Menu Lateral</h3>
            <br>
            <ul>
                <li style="list-style: none; margin-bottom: 10px;"><a href="#" style="color: #333; text-decoration: none;">👤 Funcionários</a></li>
                <li style="list-style: none; margin-bottom: 10px;"><a href="#" style="color: #333; text-decoration: none;">💰 Folha de Pagamento</a></li>
                <li style="list-style: none; margin-bottom: 10px;"><a href="#" style="color: #333; text-decoration: none;">📊 Estatísticas</a></li>
            </ul>
        </aside>

        <main class="container">
            <div class="container-placeholder">
                <div class="coluna">
                    <div class="box">
                        <label for="salario">Salário Mensal:</label>
                        <input type="number" name="salario" id="salario">
                    </div>

                    <div class="box">
                        <label for="dia">Horas Necessárias:</label>
                        <input type="number" name="horas" id="hrsN">
                    </div>

                    <div class="box">
                        <label for="horas">Horas Trabalhadas:</label>
                        <input type="number" name="horasT" id="hrsT">
                    </div>
                    
                    <div class="box">
                        <button onclick="CalculoSalario()" id="salarioPorHrs">Calcular</button>
                    </div>

                    <div class="resultado-box">
                        <table border="1">
                            <tr>
                                <th>Resultado do Salário:</th>
                            </tr>
                            <tr>
                                <td id="resultado">-----</td>
                            </tr>
                        </table>
                    </div> 
                </div>
            </div>
        </main>
    </div>
</body>
<script>
    function CalculoSalario(){
    let valorMensal = document.getElementById("salario").value;
    let horasT = document.getElementById("hrsT").value;
    let horasN = document.getElementById("hrsN").value;
    
    let salarioPorDia = valorMensal * horasT
    salarioPorHora = salarioPorDia/horasN;

    document.getElementById("resultado").innerText = "Salário por Hora: R$ " + salarioPorHora.toFixed(2);
}
</script>
</html>
